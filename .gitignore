# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local styling sandbox — not deployed (blocked by proxy.ts)
/app/home-test/

# original photos — never commit; convert to WebP in public/images/ instead
/assets/originals/*
!/assets/originals/.gitkeep

# GTM setup tool — OAuth secrets (copy tools/gtm-setup/ to other projects)
/tools/gtm-setup/node_modules/
/tools/gtm-setup/oauth/client_secret.json
/tools/gtm-setup/oauth/token.json
